{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "types": ["node", "mocha"]
  },
  "include": ["./scripts", "./test", "./typechain", "./hardhat.config.ts"],
  "exclude": ["node_modules"]
}
