{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "isolatedModules": true,
    "types": ["node", "mocha"]
  },
  "include": ["./src", "./scripts", "./test", "./hardhat.config.ts", "./next-env.d.ts"],
  "exclude": ["node_modules"]
}
